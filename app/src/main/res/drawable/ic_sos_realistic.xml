        <shape android:shape="oval">
            <solid android:color="#20FF0000" />
            <size android:width="200dp" android:height="200dp" />
        </shape>
    </item>
    <!-- Main Button Body -->
    <item android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#D32F2F"
                android:startColor="#F44336"
                android:type="linear" />
            <stroke android:width="2dp" android:color="#B71C1C" />
        </shape>
    </item>
    <!-- Inner Glossy Effect -->
