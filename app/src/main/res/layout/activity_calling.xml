<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C2C2E">

    <!-- Timer and Call Icon -->
    <LinearLayout
        android:id="@+id/llTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_call"
            android:contentDescription="Call timer icon"
            app:tint="#00B0FF" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="00 : 10 : 45"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Caller Name -->
    <TextView
        android:id="@+id/tvCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/llTimer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="SOS Emergency"
        android:textColor="@color/white"
        android:textSize="36sp" />

    <!-- Phone Number -->
    <TextView
        android:id="@+id/tvPhoneNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvCallerName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="12 34 5678"
        android:textColor="#00B0FF"
        android:textSize="20sp" />

    <!-- Caller Image Placeholder -->
    <FrameLayout
        android:id="@+id/flCallerImage"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_below="@id/tvPhoneNumber"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/ic_launcher_background"
            android:alpha="0.2" />

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_report_image"
            android:contentDescription="Caller profile image"
            app:tint="#A0A0A0" />
    </FrameLayout>

    <!-- Call Controls Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/flCallerImage"
        android:layout_marginTop="60dp"
        android:columnCount="3"
        android:paddingHorizontal="40dp">

        <!-- Mute -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_lock_silent_mode"
                android:contentDescription="Mute call"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mute"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Keypad -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_dialog_dialer"
                android:contentDescription="Keypad"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keypad"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Speaker -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:contentDescription="Speaker"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speaker"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Video Call -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/presence_video_online"
                android:contentDescription="Video call"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video call"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Add call -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_add"
                android:contentDescription="Add call"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add call"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Contacts -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:contentDescription="Contacts"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contacts"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

    </GridLayout>

    <!-- End Call Button -->
    <ImageView
        android:id="@+id/btnEndCall"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        android:background="@android:drawable/presence_video_online"
        android:backgroundTint="#FF3B30"
        android:padding="20dp"
        android:src="@android:drawable/ic_menu_call"
        android:rotation="135"
        android:contentDescription="End call"
        app:tint="@color/white" />

</RelativeLayout>
