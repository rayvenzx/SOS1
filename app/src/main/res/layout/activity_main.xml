<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- Custom Top Bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_icon"
                android:padding="8dp"
                android:src="@drawable/lines" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="S.O.S"
                android:textColor="#800000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivProfileIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_icon"
                android:padding="4dp"
                android:src="@drawable/dp" />

            <ImageView
                android:id="@+id/ivLocationIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_icon"
                android:padding="8dp"
                android:src="@drawable/loc" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Location Address Area -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cvTracking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#F8F8F8"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvLocationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="20dp"
                        android:text="My location"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <!-- Quick Service Icons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/cvPolice"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="12dp"
                        android:src="@drawable/popo" />

                    <ImageView
                        android:id="@+id/cvMedical"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="12dp"
                        android:src="@drawable/ambu1" />

                    <ImageView
                        android:id="@+id/cvFire"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="12dp"
                        android:src="@drawable/fire" />
                </LinearLayout>

                <!-- Large Circular SOS Button -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp">

                    <View
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:background="@drawable/bg_status_capsule"
                        android:backgroundTint="#CCCCCC" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="240dp"
                        android:layout_height="240dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="#FF0000"
                        app:cardCornerRadius="120dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/btnSos"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="40dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/sos1" />
                    </androidx.cardview.widget.CardView>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:gravity="center"
                    android:paddingHorizontal="40dp"
                    android:text="Go to the settings and add members to the SOS list"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Hidden Map for OSMDroid initialization -->
                <org.osmdroid.views.MapView
                    android:id="@+id/map"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />

                <!-- Required for original logic -->
                <EditText
                    android:id="@+id/etSosReason"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />
                <LinearLayout
                    android:id="@+id/llContactList"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            style="@style/Widget.App.BottomNavigationView"
            android:layout_width="370dp"
            android:layout_height="118dp"
            android:background="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:menu="@menu/bottom_nav_menu"
            tools:layout_editor_absoluteX="-4dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>